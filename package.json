{
    "author": "Friedemann Sommer <contact@friedemannsommer.com>",
    "bugs": {
        "url": "https://github.com/friedemannsommer/lcov-parser/issues"
    },
    "description": "A LCOV file parser.",
    "devDependencies": {
        "@arethetypeswrong/core": "0.18.4",
        "@biomejs/biome": "2.5.1",
        "@changesets/changelog-github": "0.7.0",
        "@changesets/cli": "2.31.0",
        "@types/node": "24.13.2",
        "c8": "11.0.0",
        "publint": "0.3.21",
        "tsdown": "0.22.3",
        "tsx": "4.22.4",
        "typedoc": "0.28.19",
        "typedoc-github-theme": "0.4.0",
        "typedoc-plugin-mdn-links": "5.1.1",
        "typescript": "5.9.3",
        "unplugin-unused": "0.5.7"
    },
    "engines": {
        "node": ">=22"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./constants": {
            "import": {
                "types": "./dist/constants.d.mts",
                "default": "./dist/constants.mjs"
            },
            "require": {
                "types": "./dist/constants.d.cts",
                "default": "./dist/constants.cjs"
            }
        },
        "./lib/field-variant": {
            "import": {
                "types": "./dist/lib/field-variant.d.mts",
                "default": "./dist/lib/field-variant.mjs"
            },
            "require": {
                "types": "./dist/lib/field-variant.d.cts",
                "default": "./dist/lib/field-variant.cjs"
            }
        },
        "./parser": {
            "import": {
                "types": "./dist/parser.d.mts",
                "default": "./dist/parser.mjs"
            },
            "require": {
                "types": "./dist/parser.d.cts",
                "default": "./dist/parser.cjs"
            }
        },
        "./promise": {
            "import": {
                "types": "./dist/promise/index.d.mts",
                "default": "./dist/promise/index.mjs"
            },
            "require": {
                "types": "./dist/promise/index.d.cts",
                "default": "./dist/promise/index.cjs"
            }
        },
        "./stream": {
            "import": {
                "types": "./dist/stream/index.d.mts",
                "default": "./dist/stream/index.mjs"
            },
            "require": {
                "types": "./dist/stream/index.d.cts",
                "default": "./dist/stream/index.cjs"
            }
        },
        "./sync": {
            "import": {
                "types": "./dist/sync/index.d.mts",
                "default": "./dist/sync/index.mjs"
            },
            "require": {
                "types": "./dist/sync/index.d.cts",
                "default": "./dist/sync/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "homepage": "https://friedemannsommer.github.io/lcov-parser/",
    "keywords": [
        "lcov",
        "parse",
        "parser"
    ],
    "license": "MIT",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "name": "@friedemannsommer/lcov-parser",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/friedemannsommer/lcov-parser.git"
    },
    "scripts": {
        "build": "tsdown",
        "check": "npm run check:biome && npm run check:ts",
        "check:biome": "biome check src",
        "check:ci": "biome ci src && npm run check:ts",
        "check:ts": "tsc --project tsconfig.json --noEmit",
        "coverage": "c8 node --import tsx --test 'src/tests/**/*.spec.ts'",
        "docs": "typedoc",
        "release": "npm run build && changeset publish",
        "test": "node --import tsx --test 'src/tests/**/*.spec.ts'"
    },
    "sideEffects": false,
    "type": "module",
    "types": "./dist/index.d.mts",
    "version": "6.0.0"
}
